# =======================================================================
# Naust - Docker Configuration
# =======================================================================
# Copy to .env and fill in your values before running docker compose.
#
# Optional services need both a flag below AND the matching Compose profile:
#   docker compose --profile rav --profile radicale up -d
#
# Available profiles: rav, filebrowser, radicale, munin, beszel, clamav
# =======================================================================

# == Required =============================================================
# If testing local development, set the following:
# - PRIMARY_HOSTNAME=localhost
# - PUBLIC_IP=127.0.0.1
#
# Or else, let boxctl fill in the values for you when you run `boxctl setup`.
PRIMARY_HOSTNAME=mail.example.com
PUBLIC_IP=1.2.3.4

# == Ports ================================================================
# Defaults are safe for local/dev use (avoids conflicts with systemd-resolved
# and residential ISP port blocks). For production, use docker-compose.prod.yml
# which overrides these to the standard ports, or set them explicitly here.
#PORT_DNS=5354
#PORT_HTTP=80
#PORT_HTTPS=443
#PORT_SMTP=25
#PORT_SMTPS=465
#PORT_SUBMISSION=587
#PORT_IMAPS=993
#PORT_SIEVE=4190

# == Network ==============================================================
# Leave blank if your server doesn't have a public IPv6 address.
PUBLIC_IPV6=

# == Storage ==============================================================
# Backed by the mail-data named volume. Only change if using a custom mount.
STORAGE_ROOT=/home/user-data

# == DNS ==================================================================
# self     - This box is the authoritative nameserver.
#            Requires NS records at your registrar pointing here.
# external - DNS is managed elsewhere (Cloudflare, Route53, etc.).
#            Suppresses nameserver warnings in the status panel.
DNS_MODE=self

# == Webmail ==============================================================
# rav - fast Rust-based client  (needs --profile rav)
# none          - No webmail, use Thunderbird / Apple Mail / etc.
WEBMAIL_CLIENT=rav

# == Optional Services ====================================================
# Set to true AND pass the matching --profile flag when starting.
ENABLE_FILEBROWSER=false  # --profile filebrowser  (file manager at /files)
ENABLE_RADICALE=false     # --profile radicale     (CalDAV/CardDAV sync)
ENABLE_CLAMAV=false       # --profile clamav       (ClamAV antivirus milter)
# MONITORING_TOOL=beszel  # --profile beszel       (Beszel system monitoring)
# CLAMAV_HOST=clamav      # override if running clamav container under a different name

# == Backup ===============================================================
# restic     - Faster, deduplicating backups. Recommended for new installs.
# duplicity  - The original backup tool. Still fully supported.
# Switching later starts a brand-new, empty backup history under the new
# tool - existing backups are left in place but no longer managed.
BACKUP_TOOL=restic

# == Mail =================================================================
# MTA-STS enforcement mode: enforce | testing | none
MTA_STS_MODE=enforce

# Dovecot plain IMAP bind address (port 143).
# Default is 127.0.0.1 (loopback). Set to 0.0.0.0 when the webmail client
# runs in a separate container or host that cannot reach loopback.
DOVECOT_IMAP_BIND=0.0.0.0
